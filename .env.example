# Server-side/automation secrets. Never expose these through browser JavaScript,
# a committed file, a Pages artifact, or generated public JSON.
MET_OFFICE_API_KEY=
YOUTUBE_API_KEY=
X_BEARER_TOKEN=

# Actions supplies github.token automatically. A local value, if deliberately
# used for quota integration testing, must be short-lived and limited to this
# repository's Contents write permission.
WEATHERCHART_QUOTA_TOKEN=
WEATHERCHART_QUOTA_BRANCH=weatherchart-quota-state
WEATHERCHART_QUOTA_PATH=.weatherchart-quota/met-office-global-spot.json

# Optional local/deployment overrides.
WEATHERCHART_DEPLOYED_DATA_BASE=https://brexatlas.github.io/WeatherChartUK/data/
MET_OFFICE_WARNINGS_RSS_URL=
MET_OFFICE_NEWS_RSS_URL=

# The 350-attempt UTC-day maximum, 12-location batch size, and freshness window
# are hard-coded safety invariants and are intentionally not configurable here.
